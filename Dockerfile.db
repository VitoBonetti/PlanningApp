FROM postgres:15-alpine

# Install OpenSSL, generate the certs, and set the strict permissions required by Postgres
RUN apk add --no-cache openssl && \
    mkdir -p /etc/ssl/certs && \
    openssl req -new -x509 -days 3650 -nodes -text -out /etc/ssl/certs/server.crt \
    -keyout /etc/ssl/certs/server.key -subj "/CN=db" && \
    chmod 0600 /etc/ssl/certs/server.key && \
    chown -R postgres:postgres /etc/ssl/certs

# Override the default command to force SSL on startup
CMD ["postgres", "-c", "ssl=on", "-c", "ssl_cert_file=/etc/ssl/certs/server.crt", "-c", "ssl_key_file=/etc/ssl/certs/server.key"]